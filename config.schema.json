{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JWWon/robro/config.schema.json",
  "title": "Robro Project Configuration",
  "description": "Project-level configuration for the robro Claude Code plugin. All fields are optional — omitted fields use built-in defaults from config.json.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "model": {
      "type": "string",
      "enum": ["haiku", "sonnet", "opus"],
      "description": "Claude model tier for agent dispatch"
    },
    "generic_provider": {
      "type": "object",
      "description": "External AI provider configuration",
      "additionalProperties": false,
      "properties": {
        "model": {
          "type": "string",
          "description": "Model identifier for the provider"
        },
        "timeout_ms": {
          "type": "integer",
          "description": "Invocation timeout in milliseconds",
          "default": 300000
        },
        "strengths": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Advisory focus areas for gate-to-provider routing. Used by advisory-start.sh to determine designated provider per agent role."
        }
      }
    },
    "codex_provider": {
      "type": "object",
      "description": "Codex (OpenAI) provider configuration",
      "additionalProperties": false,
      "properties": {
        "model": {
          "type": "string",
          "description": "Codex model identifier"
        },
        "timeout_ms": {
          "type": "integer",
          "description": "Invocation timeout in milliseconds",
          "default": 300000
        },
        "strengths": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Advisory focus areas for gate-to-provider routing. Codex: code-review, code-analysis, security-audit, critical-thinking. Gemini: multimodal, large-context, ui-analysis."
        }
      }
    },
    "model_capped": {
      "type": "string",
      "enum": ["haiku", "sonnet"],
      "description": "Claude model tier capped at sonnet (for researcher, retro-analyst, conflict-resolver)"
    },
    "tier_config": {
      "type": "object",
      "description": "Model assignments for a complexity tier",
      "additionalProperties": false,
      "properties": {
        "default": { "$ref": "#/$defs/model" },
        "builder": { "$ref": "#/$defs/model" },
        "reviewer": { "$ref": "#/$defs/model" },
        "architect": { "$ref": "#/$defs/model" },
        "critic": { "$ref": "#/$defs/model" },
        "researcher": { "$ref": "#/$defs/model_capped" },
        "retro-analyst": { "$ref": "#/$defs/model_capped" },
        "conflict-resolver": { "$ref": "#/$defs/model_capped" },
        "planner": { "$ref": "#/$defs/model" },
        "contrarian": { "$ref": "#/$defs/model" },
        "simplifier": { "$ref": "#/$defs/model" },
        "ontologist": { "$ref": "#/$defs/model" }
      }
    },
    "generic_provider": {
      "type": "object",
      "description": "Generic external CLI provider configuration",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether this provider is active. Hook skips disabled providers.",
          "default": false
        },
        "binary": {
          "type": "string",
          "description": "CLI binary name to look up via command -v (e.g. 'codex', 'gemini')"
        },
        "model": {
          "type": "string",
          "description": "Model identifier passed to the CLI (e.g. 'o4-mini', 'gemini-2.5-pro')"
        },
        "strengths": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Advisory focus areas for routing (e.g. ['code-review', 'multimodal'])"
        },
        "timeout_ms": {
          "type": "integer",
          "description": "Maximum milliseconds to wait for this provider's response",
          "minimum": 5000,
          "maximum": 600000,
          "default": 300000
        }
      },
      "required": ["enabled"]
    },
    "codex_provider": {
      "type": "object",
      "description": "Codex CLI provider with approval and sandbox options",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "binary": { "type": "string" },
        "model": { "type": "string" },
        "strengths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 5000,
          "maximum": 600000,
          "default": 300000
        },
        "approval_mode": {
          "type": "string",
          "enum": ["suggest", "auto-edit", "full-auto"],
          "description": "Codex approval mode (--full-auto for headless)",
          "default": "full-auto"
        },
        "sandbox": {
          "type": "boolean",
          "description": "Whether to run Codex in --sandbox mode for read-only analysis",
          "default": true
        }
      },
      "required": ["enabled"]
    },
    "gemini_provider": {
      "type": "object",
      "description": "Gemini CLI provider with approval and thinking options",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "binary": { "type": "string" },
        "model": { "type": "string" },
        "strengths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 5000,
          "maximum": 600000,
          "default": 300000
        },
        "approval_mode": {
          "type": "string",
          "enum": ["default", "yolo"],
          "description": "Gemini --approval-mode flag (yolo for headless)",
          "default": "yolo"
        },
        "thinking_level": {
          "type": "string",
          "enum": ["none", "auto", "high"],
          "description": "Gemini thinking level",
          "default": "auto"
        }
      },
      "required": ["enabled"]
    }
  },
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Path to this schema file for editor validation"
    },
    "providers": {
      "type": "object",
      "description": "External AI provider configurations for multi-model advisory",
      "additionalProperties": false,
      "properties": {
        "codex": { "$ref": "#/$defs/codex_provider" },
        "gemini": { "$ref": "#/$defs/generic_provider" }
      }
    },
    "model_tiers": {
      "type": "object",
      "description": "Override model assignments per complexity tier. Unspecified agents use config.json defaults.",
      "additionalProperties": false,
      "properties": {
        "light": { "$ref": "#/$defs/tier_config" },
        "standard": { "$ref": "#/$defs/tier_config" },
        "complex": { "$ref": "#/$defs/tier_config" }
      }
    },
    "thresholds": {
      "type": "object",
      "description": "Override skill thresholds",
      "additionalProperties": false,
      "properties": {
        "ambiguity_threshold": {
          "type": "number",
          "description": "Maximum ambiguity score to pass the idea/plan gate. Lower = stricter.",
          "default": 0.1,
          "minimum": 0.0,
          "maximum": 1.0
        },
        "sprint_hard_cap": {
          "type": "integer",
          "description": "Maximum number of sprints before forcing convergence.",
          "default": 30,
          "minimum": 1,
          "maximum": 100
        },
        "plan_max_iterations": {
          "type": "integer",
          "description": "Maximum review iterations in plan skill. 0 = no cap (quality-driven).",
          "default": 0,
          "minimum": 0
        },
        "build_progress_max_sprints": {
          "type": "integer",
          "default": 5,
          "minimum": 1,
          "description": "Maximum sprint sections to inject from build-progress.md into retro context"
        },
        "oscillation_cycle_threshold": {
          "type": "integer",
          "default": 3,
          "minimum": 2,
          "description": "Number of same-file edit cycles before oscillation warning triggers"
        },
        "wonder_min_sprint": {
          "type": "integer",
          "default": 3,
          "minimum": 1,
          "description": "Minimum sprint number before Wonder agent can be dispatched"
        },
        "skill_injection_cap": {
          "type": "integer",
          "default": 5,
          "minimum": 1,
          "description": "Maximum learned skills injected per session"
        }
      }
    },
    "agent_overrides": {
      "type": "object",
      "description": "Per-agent model overrides. Takes highest precedence over tier defaults.",
      "additionalProperties": false,
      "properties": {
        "builder": { "$ref": "#/$defs/model" },
        "reviewer": { "$ref": "#/$defs/model" },
        "architect": { "$ref": "#/$defs/model" },
        "critic": { "$ref": "#/$defs/model" },
        "researcher": { "$ref": "#/$defs/model_capped" },
        "retro-analyst": { "$ref": "#/$defs/model_capped" },
        "conflict-resolver": { "$ref": "#/$defs/model_capped" },
        "planner": { "$ref": "#/$defs/model" },
        "contrarian": { "$ref": "#/$defs/model" },
        "simplifier": { "$ref": "#/$defs/model" },
        "ontologist": { "$ref": "#/$defs/model" }
      }
    },
    "providers": {
      "type": "object",
      "description": "External CLI provider configurations. Named providers (codex, gemini) get typed validation; additional providers use the generic schema.",
      "properties": {
        "codex": { "$ref": "#/$defs/codex_provider" },
        "gemini": { "$ref": "#/$defs/gemini_provider" }
      },
      "additionalProperties": { "$ref": "#/$defs/generic_provider" }
    }
  }
}
